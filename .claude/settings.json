{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/routing-hook.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/correction-detector.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/block-protect.sh scan",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.claude/scripts/compact-restore.py\"",
            "timeout": 10,
            "statusMessage": "Restoring context after compaction..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/guard.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/env-leak-scanner.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/security-scan.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/config-protect.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/block-protect.sh check",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/dispatch-gate.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.claude/hooks/context-threshold-stop.py\"",
            "timeout": 5,
            "statusMessage": "Checking context threshold..."
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/commit-reminder.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/memory-save-hook.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/stall-detector.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/vbr-gate.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/turn-cadence-gate.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/no-tool-gate.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/session-stop.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/block-protect.sh cleanup",
            "timeout": 3
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/turn-counter.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/persona-anchor.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/loop-detector.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/post-compact.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/subagent-channel.sh",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/error-detector.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/agent-postcheck.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.claude/scripts/pre-compact.py\"",
            "timeout": 15
          }
        ]
      }
    ]
  },
  "permissions": {
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(rm -rf /*:*)",
      "Bash(sudo rm -rf:*)",
      "Bash(sudo:*)",
      "Bash(mkfs:*)",
      "Bash(dd:*)",
      "Bash(format:*)"
    ]
  },
  "enabledPlugins": {}
}
