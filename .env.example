# ═══════════════════════════════════════════
#  Orchestrator Configuration
# ═══════════════════════════════════════════
#  Copy to .env and fill in your values.
#  Lines starting with # are disabled.
# ═══════════════════════════════════════════

# ── API Keys ──
# Only needed for Docker standalone mode.
# In Claude Code, Agent SDK uses Claude Code auth automatically.
ANTHROPIC_API_KEY=sk-ant-...

# ── Collectors ──
# Enabled by default. Comment out to disable.
COLLECTOR_CLAUDE=true
COLLECTOR_BROWSER=true
COLLECTOR_GIT=true
COLLECTOR_VSCODE=true
COLLECTOR_NETWORK=true
COLLECTOR_CODEBASE=true
# COLLECTOR_STEAM=true
# COLLECTOR_YOUTUBE_MUSIC=true
# COLLECTOR_QQMUSIC=true

# Custom paths (leave empty for auto-detection)
# GIT_PATHS=~/Documents/GitHub,~/Projects

# ── Local LLM (Ollama) ──
# Used for: scrutiny review, debt scanning, vision tasks
# Without it: falls back to Claude API (costs more tokens)
# OLLAMA_HOST=http://localhost:11434

# ── TTS (Fish Speech) ──
# Used for: voice playback on Dashboard
# Without it: voice button disabled, everything else works
# TTS_HOST=http://localhost:23715

# ── Dashboard ──
PORT=23714

# ── Docker volume mounts ──
# Only needed for Docker mode. Adjust to your OS.
#
# Windows:
#   CHROME_USER_DATA=C:/Users/YOU/AppData/Local/Google/Chrome/User Data
#   CLAUDE_HOME_HOST=C:/Users/YOU/.claude
#   GIT_ROOT=C:/Users/YOU/Documents/GitHub
#   VSCODE_DATA=C:/Users/YOU/AppData/Roaming/Code/User
#   STEAM_PATH_HOST=D:/Steam
#   QQMUSIC_DATA=C:/Users/YOU/AppData/Roaming/Tencent/QQMusic
#
# macOS:
#   CHROME_USER_DATA=~/Library/Application Support/Google/Chrome
#   CLAUDE_HOME_HOST=~/.claude
#   GIT_ROOT=~/Documents/GitHub
#   VSCODE_DATA=~/Library/Application Support/Code/User
#
# Linux:
#   CHROME_USER_DATA=~/.config/google-chrome
#   CLAUDE_HOME_HOST=~/.claude
#   GIT_ROOT=~/Projects
#   VSCODE_DATA=~/.config/Code/User

CHROME_USER_DATA=
CLAUDE_HOME_HOST=
GIT_ROOT=
STEAM_PATH_HOST=
QQMUSIC_DATA=
VSCODE_DATA=
