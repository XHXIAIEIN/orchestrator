ANTHROPIC_API_KEY=sk-ant-...

# ── Docker volume mounts ──
# Adjust paths below to match your system.
# All paths are required for Docker mode.

# Windows example:
# CHROME_USER_DATA=C:/Users/YOUR_USERNAME/AppData/Local/Google/Chrome/User Data
# CLAUDE_HOME_HOST=C:/Users/YOUR_USERNAME/.claude
# GIT_ROOT=C:/Users/YOUR_USERNAME/Documents/GitHub
# STEAM_PATH_HOST=D:/Steam
# QQMUSIC_DATA=C:/Users/YOUR_USERNAME/AppData/Roaming/Tencent/QQMusic
# VSCODE_DATA=C:/Users/YOUR_USERNAME/AppData/Roaming/Code/User

# macOS example:
# CHROME_USER_DATA=/Users/YOUR_USERNAME/Library/Application Support/Google/Chrome
# CLAUDE_HOME_HOST=/Users/YOUR_USERNAME/.claude
# GIT_ROOT=/Users/YOUR_USERNAME/Documents/GitHub
# STEAM_PATH_HOST=/Users/YOUR_USERNAME/Library/Application Support/Steam
# QQMUSIC_DATA=/Users/YOUR_USERNAME/Library/Containers/com.tencent.QQMusicMac
# VSCODE_DATA=/Users/YOUR_USERNAME/Library/Application Support/Code/User

# Linux example:
# CHROME_USER_DATA=/home/YOUR_USERNAME/.config/google-chrome
# CLAUDE_HOME_HOST=/home/YOUR_USERNAME/.claude
# GIT_ROOT=/home/YOUR_USERNAME/Projects
# STEAM_PATH_HOST=/home/YOUR_USERNAME/.steam
# QQMUSIC_DATA=/tmp/qqmusic-placeholder
# VSCODE_DATA=/home/YOUR_USERNAME/.config/Code/User

# Uncomment and fill in YOUR paths:
CHROME_USER_DATA=
CLAUDE_HOME_HOST=
GIT_ROOT=
STEAM_PATH_HOST=
QQMUSIC_DATA=
VSCODE_DATA=
